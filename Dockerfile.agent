# EvoBench CLI Agent 评测镜像
# 包含：YatCC 完整构建环境 + Claude Code + Codex CLI + Kimi CLI
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Shanghai

# 系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential git python3 python3-dev python3-pip cmake ninja-build \
    default-jdk bison flex unzip wget lld libncurses-dev libzstd-dev \
    qemu-user-static gcc-riscv64-linux-gnu g++-riscv64-linux-gnu \
    llvm-18 clang-18 ca-certificates curl sudo \
    && rm -rf /var/lib/apt/lists/*

# 创建非 root 用户
RUN useradd -m -s /bin/bash agent && \
    echo "agent ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# 安装 Node.js (Claude Code / Codex 需要)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs && \
    npm install -g @anthropic-ai/claude-code @openai/codex

# 安装 Kimi CLI
RUN pip3 install --break-system-packages kimi-cli

# 安装 Python 依赖
RUN pip3 install --break-system-packages openai python-dotenv pyyaml click

# 复制 YatCC 源码
COPY --chown=agent:agent YatCC/ /workspace/YatCC/

# 预构建依赖（作为 root，然后切换到 agent）
RUN cd /workspace/YatCC && \
    bash antlr/setup.sh && \
    bash llvm/setup.sh && \
    bash pybind11/setup.sh && \
    bash task5_setup.sh

# 预配置 CMake + 生成标准答案
RUN cd /workspace/YatCC && \
    cmake -S . -B build -G Ninja \
    -DSTUDENT_ID=EvoBench -DSTUDENT_NAME=Agent \
    -DTASK1_WITH=flex -DTASK2_WITH=bison \
    -DTASK2_REVIVE=OFF -DTASK3_REVIVE=OFF \
    -DTASK4_REVIVE=OFF -DTASK5_REVIVE=OFF && \
    cmake --build build -t test-rtlib && \
    cmake --build build -t task0-answer task1-answer task2-answer task3-answer task5-answer && \
    cmake --build build -t task0 task1 task2 task3 task4 task5-classic

# 验证构建
RUN cd /workspace/YatCC && cmake --build build -t task0-score

# 切换到 agent 用户
USER agent
WORKDIR /workspace/YatCC

# 默认命令
CMD ["/bin/bash"]
